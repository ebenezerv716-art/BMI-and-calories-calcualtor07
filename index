<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Advanced Health & Diet Calculator</title>

<style>
body {
  font-family: Arial;
  background: linear-gradient(to right,#00c6ff,#0072ff);
  text-align: center;
  color: #333;
}
.container {
  background: #fff;
  padding: 20px;
  margin: 20px auto;
  width: 420px;
  border-radius: 12px;
  box-shadow: 0 5px 20px rgba(0,0,0,0.2);
}
input, select, button {
  width: 90%;
  padding: 10px;
  margin: 8px;
  border-radius: 6px;
}
button {
  background: #28a745;
  color: white;
  border: none;
  font-weight: bold;
}
.result {
  text-align: left;
  margin-top: 10px;
}
</style>
</head>

<body>

<!-- 👤 HUMAN -->
<div class="container">
<h2>👤 BMI & Calorie Calculator</h2>

<input type="number" id="age" placeholder="Age">
<input type="number" id="weight" placeholder="Weight (kg)">
<input type="number" id="height" placeholder="Height (cm)">

<select id="activity">
  <option value="1.2">Sedentary</option>
  <option value="1.375">Light Exercise</option>
  <option value="1.55">Moderate Exercise</option>
  <option value="1.725">Heavy Exercise</option>
</select>

<select id="gender">
  <option value="male">Male</option>
  <option value="female">Female</option>
</select>

<button onclick="calcHuman()">Calculate</button>

<div class="result" id="humanResult"></div>
</div>

<!-- 🍽️ FOOD -->
<div class="container">
<h2>🍽️ Food Nutrition Calculator</h2>

<input list="foods" id="food" placeholder="Search food...">
<datalist id="foods"></datalist>

<input type="number" id="qty" placeholder="Quantity (grams)">

<button onclick="calcFood()">Calculate</button>

<div class="result" id="foodResult"></div>
</div>

<script>

// 👤 HUMAN CALCULATION
function calcHuman() {
  let age = age.value;
  let weight = weight.value;
  let height = height.value;
  let gender = gender.value;
  let activity = activity.value;

  let bmi = weight / ((height/100)**2);

  let status = bmi<18.5?"Underweight":
               bmi<25?"Normal":
               bmi<30?"Overweight":"Obese";

  let bmr = gender==="male"
    ? 10*weight + 6.25*height - 5*age + 5
    : 10*weight + 6.25*height - 5*age - 161;

  let maintenance = bmr * activity;
  let deficit = maintenance - 500;

  let diet = deficit < 1800
    ? "🥗 Eat more protein, fruits & vegetables"
    : "🍗 Balanced diet with carbs, protein & fats";

  humanResult.innerHTML = `
  📊 BMI: ${bmi.toFixed(1)} (${status})<br>
  🔥 BMR: ${Math.round(bmr)} kcal<br>
  ⚡ Maintenance Calories: ${Math.round(maintenance)} kcal<br>
  📉 Weight Loss Calories: ${Math.round(deficit)} kcal<br>
  🥗 Diet Suggestion: ${diet}
  `;
}

// 🍽️ FOOD DATABASE (per 100g)
const foods = {

  // Indian Meals
  biryani:{cal:250,protein:6,carbs:35,fat:10},
  sambar_rice:{cal:180,protein:5,carbs:30,fat:4},
  curd_rice:{cal:150,protein:4,carbs:25,fat:3},
  dosa:{cal:168,protein:4,carbs:27,fat:3},
  idli:{cal:58,protein:2,carbs:12,fat:0.4},

  // Vegetables
  potato:{cal:77,protein:2,carbs:17,fat:0.1},
  carrot:{cal:41,protein:0.9,carbs:10,fat:0.2},
  spinach:{cal:23,protein:2.9,carbs:3.6,fat:0.4},
  tomato:{cal:18,protein:0.9,carbs:3.9,fat:0.2},

  // Fruits
  apple:{cal:52,protein:0.3,carbs:14,fat:0.2},
  banana:{cal:89,protein:1.1,carbs:23,fat:0.3},
  mango:{cal:60,protein:0.8,carbs:15,fat:0.4},
  orange:{cal:47,protein:0.9,carbs:12,fat:0.1},

  // Protein
  egg:{cal:155,protein:13,carbs:1.1,fat:11},
  chicken:{cal:239,protein:27,carbs:0,fat:14},
  paneer:{cal:265,protein:18,carbs:1.2,fat:20}
};

// Dropdown
let list = document.getElementById("foods");
Object.keys(foods).forEach(f=>{
  let opt=document.createElement("option");
  opt.value=f;
  list.appendChild(opt);
});

// FOOD CALCULATION
function calcFood(){
  let f = food.value.toLowerCase();
  let q = qty.value;

  if(foods[f]){
    let d = foods[f];
    let factor = q/100;

    foodResult.innerHTML = `
    🔥 Calories: ${(d.cal*factor).toFixed(1)} kcal<br>
    🥩 Protein: ${(d.protein*factor).toFixed(1)} g<br>
    🍞 Carbs: ${(d.carbs*factor).toFixed(1)} g<br>
    🧈 Fat: ${(d.fat*factor).toFixed(1)} g
    `;
  } else {
    foodResult.innerHTML="⚠️ Food not found!";
  }
}

</script>

</body>
</html>
